<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ phone.name }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #fafafa; font-family: Georgia, serif; }
        .navbar-custom { background: linear-gradient(90deg, #6b0f1a, #b91c1c); padding: 15px 0; }
        .navbar-brand { color: #ffd700 !important; font-weight: 900; font-size: 1.5rem; letter-spacing: 3px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-custom mb-5">
        <div class="container">
            <a class="navbar-brand" href="/phone">PHONE STORE</a>
            <a href="/phone" class="btn" style="background:#ffd700; color:#6b0f1a; font-weight:700; border-radius:25px;">Retour</a>
        </div>
    </nav>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow" style="border-radius:15px; border:none; border-top:4px solid #6b0f1a;">
                    <div class="card-body p-5">
                        <h2 class="fw-bold mb-4" style="color:#6b0f1a;">{{ phone.name }}</h2>
                        <table class="table">
                            <tr>
                                <th style="color:#6b0f1a;">Id</th>
                                <td>{{ phone.id }}</td>
                            </tr>
                            <tr>
                                <th style="color:#6b0f1a;">Nom</th>
                                <td>{{ phone.name }}</td>
                            </tr>
                            <tr>
                                <th style="color:#6b0f1a;">Marque</th>
                                <td>{{ phone.brand }}</td>
                            </tr>
                            <tr>
                                <th style="color:#6b0f1a;">Prix</th>
                                <td>{{ phone.price }} €</td>
                            </tr>
                        </table>
                        <a href="/phone" class="btn w-100 mt-3" style="background: linear-gradient(90deg, #6b0f1a, #b91c1c); color:#ffd700; border-radius:10px; font-weight:700;">
                            Retour à la liste
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
