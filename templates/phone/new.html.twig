<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Ajouter un téléphone</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #fafafa; font-family: Georgia, serif; }
        .navbar-custom { background: linear-gradient(90deg, #6b0f1a, #b91c1c); padding: 15px 0; }
        .navbar-brand { color: #ffd700 !important; font-weight: 900; font-size: 1.5rem; letter-spacing: 3px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-custom mb-5">
        <div class="container">
            <a class="navbar-brand" href="/phone">PHONE STORE</a>
            <a href="/phone" class="btn" style="background:#ffd700; color:#6b0f1a; font-weight:700; border-radius:25px;">Retour</a>
        </div>
    </nav>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow" style="border-radius:15px; border:none; border-top:4px solid #6b0f1a;">
                    <div class="card-body p-5">
                        <h2 class="fw-bold mb-4" style="color:#6b0f1a;">Ajouter un téléphone</h2>
                        {{ form_start(form) }}
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nom</label>
                            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ex: iPhone 15 Pro'}}) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Marque</label>
                            {{ form_widget(form.brand, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Apple'}}) }}
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Prix</label>
                            {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 999.99'}}) }}
                        </div>
                        <button type="submit" class="btn w-100 py-2 fw-bold" style="background: linear-gradient(90deg, #6b0f1a, #b91c1c); color:#ffd700; border-radius:10px;">
                            Ajouter le téléphone
                        </button>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
