<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Liste des téléphones</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <h1 class="mb-4" style="color:#6b0f1a; font-weight:800;">Liste des téléphones</h1>
        <table class="table table-bordered">
            <thead>
                <tr style="background:#0A2342; color:#fff;">
                    <th>Id</th>
                    <th>Nom</th>
                    <th>Marque</th>
                    <th>Prix</th>
                </tr>
            </thead>
            <tbody>
            {% for phone in phones %}
                <tr>
                    <td>{{ phone.id }}</td>
                    <td>{{ phone.name }}</td>
                    <td>{{ phone.brand }}</td>
                    <td>{{ phone.price }} €</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center">Aucun téléphone trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
