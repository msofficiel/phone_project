<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Liste des téléphones</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #fafafa; font-family: Georgia, serif; }
        .navbar-custom { background: linear-gradient(90deg, #6b0f1a, #b91c1c); padding: 15px 0; }
        .navbar-brand { color: #ffd700 !important; font-weight: 900; font-size: 1.5rem; letter-spacing: 3px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-custom mb-5">
        <div class="container">
            <a class="navbar-brand" href="/phone">PHONE STORE</a>
            <a href="/phone/new" class="btn" style="background:#ffd700; color:#6b0f1a; font-weight:700; border-radius:25px;">+ Ajouter</a>
        </div>
    </nav>
    <div class="container">
        <h1 class="mb-4" style="color:#6b0f1a; font-weight:800;">Liste des téléphones</h1>
        <table class="table table-bordered table-striped">
            <thead>
                <tr style="background: linear-gradient(90deg, #6b0f1a, #b91c1c); color:#ffd700;">
                    <th style="padding:15px;">Id</th>
                    <th style="padding:15px;">Nom</th>
                    <th style="padding:15px;">Marque</th>
                    <th style="padding:15px;">Prix</th>
                    <th style="padding:15px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for phone in phones %}
                <tr>
                    <td>{{ phone.id }}</td>
                    <td>{{ phone.name }}</td>
                    <td>{{ phone.brand }}</td>
                    <td>{{ phone.price }} €</td>
                    <td>
                        <a href="/phone/{{ phone.id }}" class="btn btn-sm" style="background:#6b0f1a; color:#ffd700; border-radius:20px;">Voir</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center" style="color:#6b0f1a;">Aucun téléphone trouvé</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
